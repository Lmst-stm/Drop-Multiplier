buildscript {
    repositories {
//        maven { url = "https://maven.minecraftforge.net/" }
//        mavenCentral()
        maven { url = "https://maven.aliyun.com/repository/public" }
        maven { url = "https://maven.aliyun.com/repository/forge" }
        maven { url = "https://maven.minecraftforge.net/" }
        mavenCentral()
    }
    dependencies {
        classpath "net.minecraftforge.gradle:ForgeGradle:2.3.5"
    }
}

apply plugin: 'net.minecraftforge.gradle.forge'
apply plugin: 'eclipse'
apply plugin: 'maven-publish'

version = "1.0.0"
group = "lmstmyh.dropmultiplier" // 确保你的包名这里一致
archivesBaseName = "dropmultiplier"

sourceCompatibility = targetCompatibility = '1.8'

minecraft {
    version = "1.12.2-14.23.5.2859"
    runDir = "run"

    // 1.12.2 必须使用这种格式的映射，不能用新版那种 channel/version 写法
    mappings = "stable_39"

    // 如果你有 Access Transformer，在这里指定
    // makeObfSourceJar = false
}

dependencies {
    // 在这里添加你的外部依赖，比如 Cloth Config
    // compileOnly "me.shedaniel.cloth:cloth-config-fabric:0.4.4+78.1.12.2"
}

processResources {
    inputs.property "version", project.version
    inputs.property "mcversion", project.minecraft.version

    from(sourceSets.main.resources.srcDirs) {
        include 'mcmod.info'
        expand 'version': project.version, 'mcversion': project.minecraft.version
    }

    from(sourceSets.main.resources.srcDirs) {
        exclude 'mcmod.info'
    }
}